# Copy to .env.local and adjust as needed.
# Local dev: optional auth bypass (see docs/LOCAL_QA_WORKFLOW.md)
# Set DEV_AUTH_BYPASS=true then set DEV_USER_ID to one of: admin-user | dev-user | qa-renter | qa-kyc-submitted | qa-kyc-rejected
DEV_AUTH_BYPASS=true
DEV_USER_ID=dev-user
DEV_USER_NAME=Your Name

# --- Local Google OAuth (required for "המשך עם Google" on /signin) ---
# Copy to .env.local and set real values. See docs/LOCAL_GOOGLE_AUTH.md for full setup.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-at-least-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# In Google Cloud Console (OAuth 2.0 Web application):
#   Authorized JavaScript origins:  http://localhost:3000
#   Authorized redirect URIs:        http://localhost:3000/api/auth/callback/google

# Transactional email (Resend) – optional; if unset, emails are skipped
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=notifications@lendly.co.il
# APP_BASE_URL – base URL for links in emails. In development, defaults to http://localhost:3000 if unset.
# APP_BASE_URL=https://lendly.co.il
# ADMIN_EMAIL – optional; receives dispute-opened notifications when set
# ADMIN_EMAIL=admin@lendly.co.il
